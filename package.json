{
  "name": "junie-api",
  "version": "0.3.1",
  "description": "Turn JetBrains Junie AI into an OpenAI/Anthropic API compatible server. Usable with Claude Code!",
  "keywords": [
    "proxy",
    "junie",
    "jetbrains",
    "grazie",
    "openai-compatible"
  ],
  "license": "MIT",
  "author": "ffleureau",
  "type": "module",
  "bin": {
    "junie-api": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "node --watch --import tsx ./src/main.ts",
    "lint": "eslint --cache",
    "prepack": "bun run build",
    "start": "NODE_ENV=production node ./dist/main.js",
    "typecheck": "tsc",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "hono": "^4.9.9",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.2.23",
    "tsdown": "^0.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
